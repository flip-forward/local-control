{
  "name": "flip-forward",
  "version": "0.1.5",
  "description": "Control app for flip forward split-flap displays",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "make-icon": "node scripts/make-icon.js",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "de.flipforward.control",
    "productName": "flip forward",
    "icon": "build/icon",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "keywords": [],
  "author": "Moritz Haarmann <moritz@flipforward.de>",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "playwright-core": "^1.60.0",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@fontsource/barlow": "^5.2.8",
    "bonjour-service": "^1.3.0",
    "qrcode": "^1.5.4"
  }
}
